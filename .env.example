# Neon DB - use the POOLED connection string here (port 6543, via PgBouncer)
# Found in Neon dashboard → Connection Details → "Pooled connection"
DATABASE_URL="postgresql://user:password@ep-xxx.us-east-1.aws.neon.tech/neondb?pgbouncer=true&connect_timeout=15&sslmode=require"

# Neon DB - use the DIRECT connection string here (port 5432, no pooler)
# Found in Neon dashboard → Connection Details → "Direct connection"
# Used only for prisma migrations, not runtime queries
DIRECT_URL="postgresql://user:password@ep-xxx.us-east-1.aws.neon.tech/neondb?sslmode=require"

# NextAuth - generate with: openssl rand -base64 32
AUTH_SECRET="your-secret-key-here-change-this-in-production"

# Set to your production URL when deploying (no trailing slash)
NEXTAUTH_URL="http://localhost:3000"
